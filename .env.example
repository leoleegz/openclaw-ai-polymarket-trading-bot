POLYMARKET_REST_BASE=https://gamma-api.polymarket.com
BINANCE_REST_BASE=https://fapi.binance.com

PRIVATE_KEY=your_private_key
CLOB_API_URL=https://clob.polymarket.com
CLOB_CHAIN_ID=137

CLOSE_AFTER_SECONDS=0

# ===== Market Duration =====
# 5 = 5-minute BTC markets, 15 = 15-minute BTC markets
BTC_MARKET_DURATION=5

# ===== Auto Redeem =====
# How often to check for positions to redeem (in seconds)
REDEEM_CHECK_INTERVAL_SEC=30

# ===== Gas Management =====
# Automatically swap USDC.e to MATIC when gas is low
AUTO_SWAP_GAS=true
# Minimum MATIC balance before triggering swap (in MATIC, not wei)
MIN_MATIC_BALANCE=0.05
# Amount of MATIC to swap each time (in MATIC)
SWAP_AMOUNT_MATIC=0.1
# Minimum USDC.e to keep in wallet after swap (in USDC)
MIN_USDC_BALANCE=1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

LOOP_SECONDS=15
MAX_POSITION_USD=100
EDGE_THRESHOLD=0.03
CONFIDENCE_THRESHOLD=0.80
FORCE_EXIT_SECONDS=3
EMA_FAST=5
EMA_SLOW=13
RSI_PERIOD=14
WHALE_MIN_WINRATE=0.70
WHALE_MIN_NOTIONAL=200
WALLET_WINRATE_TIMEOUT_MS=3000
WALLET_WINRATE_CACHE_TTL_SEC=600
